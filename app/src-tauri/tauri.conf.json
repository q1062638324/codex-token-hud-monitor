{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Token HUD",
  "version": "0.1.3",
  "identifier": "local.codex.tokenhud",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Codex Token HUD",
        "width": 390,
        "height": 500,
        "minWidth": 48,
        "minHeight": 48,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "shadow": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:38427; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.svg",
      "icons/icon.ico"
    ]
  }
}
